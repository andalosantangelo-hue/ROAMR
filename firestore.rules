rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()        { return request.auth != null; }
    function isUser(uid)       { return signedIn() && request.auth.uid == uid; }
    function created(field)    { return request.resource.data[field] == request.auth.uid; }
    function owns(field)       { return signedIn() && resource.data[field] == request.auth.uid; }
    function keysOnly(allowed) { return request.resource.data.keys().hasOnly(allowed); }
    function unchanged(fields) { return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields); }
    function strMax(f, n)      { return request.resource.data[f] is string && request.resource.data[f].size() <= n; }

    // Collection-group reads of the current user's own presence docs
    match /{path=**}/members/{uid}   { allow read: if signedIn(); }
    match /{path=**}/likes/{uid}     { allow read: if signedIn(); }
    match /{path=**}/attendees/{uid} { allow read: if signedIn(); }

    match /users/{uid} {
      allow read: if signedIn();
      // Trust/subscription/counter fields are server-maintained. On create they must
      // be at safe defaults — otherwise a client could self-grant verified/premium/
      // ratings/vouches by writing its own user doc directly via the SDK.
      allow create: if isUser(uid)
        && keysOnly(['uid','displayName','photoURL','updatedAt',
                     'interests','subInterests','skillLevels','prompts','photos','style','pace','availability','willTravel','certifications','gearShare','lookingFor','experience','terrain','intensity','risk','type2','tripDuration','planning','fitness','trainingFor','seasons','leadTime','languages','pets','partnerWants','dealbreakers','bucketList','recentTrips','verified','verifiedTier','adventuresCompleted','ratingAvg','ratingCount','vouchCount','gender','whoCanMessage','verifiedOnly','womenOnly','bio','location','subscription','followingCount','followerCount','createdAt'])
        && request.resource.data.get('verified', false) == false
        && request.resource.data.get('verifiedTier', null) == null
        && request.resource.data.get('adventuresCompleted', 0) == 0
        && request.resource.data.get('ratingAvg', 0) == 0
        && request.resource.data.get('ratingCount', 0) == 0
        && request.resource.data.get('vouchCount', 0) == 0
        && request.resource.data.get('followerCount', 0) == 0
        && request.resource.data.get('followingCount', 0) == 0
        && request.resource.data.get('subscription', {'tier':'basic'}).tier == 'basic';
      // owner-only; counters + subscription are server-maintained
      allow update: if isUser(uid)
        && keysOnly(['uid','displayName','photoURL','bio','interests','subInterests','skillLevels','prompts','photos','style','pace','availability','willTravel','certifications','gearShare','lookingFor','experience','terrain','intensity','risk','type2','tripDuration','planning','fitness','trainingFor','seasons','leadTime','languages','pets','partnerWants','dealbreakers','bucketList','recentTrips','verified','verifiedTier','adventuresCompleted','ratingAvg','ratingCount','vouchCount','gender','whoCanMessage','verifiedOnly','womenOnly','location','subscription','followerCount','followingCount','createdAt','updatedAt'])
        && unchanged(['uid','followerCount','followingCount','subscription','createdAt','verified','verifiedTier','adventuresCompleted','ratingAvg','ratingCount','vouchCount']);
      allow delete: if isUser(uid);

      // Private profile data (email, phone, push tokens, prefs) — owner only.
      match /private/{doc} {
        allow read, write: if isUser(uid);
      }

      match /saves/{postId} {
        allow read: if isUser(uid);
        allow create: if isUser(uid) && keysOnly(['postId','collection','createdAt']);
        allow delete: if isUser(uid);
      }
      match /following/{targetUid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['targetUid','createdAt']);
        allow delete: if isUser(uid);
      }
      match /blocked/{targetUid} {
        allow read, delete: if isUser(uid);
        allow create: if isUser(uid) && keysOnly(['targetUid','createdAt']);
      }
      match /notifications/{nid} {
        allow read: if isUser(uid);
        allow update: if isUser(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false; // server-only
      }
      match /followers/{fid} { allow read: if signedIn(); allow write: if false; }
      // Vouches from people you've adventured with (one per voucher).
      match /references/{fromUid} {
        allow read: if signedIn();
        allow create: if isUser(fromUid) && fromUid != uid && created('fromUid')
          && keysOnly(['fromUid','fromName','fromPhoto','text','createdAt']) && strMax('text', 600);
        allow delete: if isUser(fromUid);
      }
      // Two-way post-trip reviews (one per reviewer). Counters are server-maintained.
      match /reviews/{reviewerUid} {
        allow read: if signedIn();
        allow create: if isUser(reviewerUid) && reviewerUid != uid && created('reviewerId')
          && keysOnly(['reviewerId','reviewerName','reviewerPhoto','ratings','overall','text','tripId','visible','createdAt'])
          && strMax('text', 1000)
          && request.resource.data.overall is number
          && request.resource.data.overall >= 1 && request.resource.data.overall <= 5;
        // overall/ratings are immutable post-create so the server-maintained ratingAvg
        // (recomputed only on create/delete) can't drift out of sync via edits.
        allow update: if isUser(reviewerUid) && unchanged(['reviewerId','overall','ratings','tripId','createdAt']);
        allow delete: if isUser(reviewerUid);
      }
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && created('authorId')
        && request.resource.data.likeCount == 0 && request.resource.data.commentCount == 0
        && keysOnly(['authorId','authorName','authorPhotoURL','title','location','photo','rating','likeCount','commentCount','createdAt'])
        && strMax('title', 300);
      allow update: if owns('authorId') && unchanged(['authorId','likeCount','commentCount','createdAt']);
      allow delete: if owns('authorId');
      match /likes/{uid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['uid','createdAt']);
        allow delete: if isUser(uid);
      }
      match /comments/{cid} {
        allow read: if signedIn();
        allow create: if signedIn() && created('authorId')
          && keysOnly(['authorId','authorName','authorPhotoURL','text','createdAt']) && strMax('text', 2000);
        allow update, delete: if owns('authorId');
      }
    }

    match /activities/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && created('authorId')
        && request.resource.data.attendeeCount == 0 && request.resource.data.likeCount == 0 && request.resource.data.commentCount == 0
        && keysOnly(['authorId','authorName','authorPhotoURL','text','photo','location','when','skillLevel','dmOpen','attendeeCount','recentAttendees','likeCount','commentCount','createdAt'])
        && strMax('text', 2000);
      allow update: if owns('authorId') && unchanged(['authorId','attendeeCount','recentAttendees','likeCount','commentCount','createdAt']);
      allow delete: if owns('authorId');
      match /attendees/{uid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['uid','displayName','photoURL','createdAt']);
        allow delete: if isUser(uid);
      }
      match /likes/{uid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['uid','createdAt']);
        allow delete: if isUser(uid);
      }
      match /comments/{cid} {
        allow read: if signedIn();
        allow create: if signedIn() && created('authorId')
          && keysOnly(['authorId','authorName','authorPhotoURL','text','createdAt']) && strMax('text', 2000);
        allow update, delete: if owns('authorId');
      }
    }

    match /tribes/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && created('ownerId') && request.resource.data.memberCount == 0
        && keysOnly(['name','img','category','categories','location','description','memberCount','ownerId','createdAt'])
        && strMax('name', 120);
      allow update: if owns('ownerId') && unchanged(['ownerId','memberCount','createdAt']);
      allow delete: if owns('ownerId');
      match /members/{uid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['uid','role','createdAt']);
        allow delete: if isUser(uid);
      }
      // Group chat — members only.
      match /messages/{mid} {
        allow read: if signedIn()
          && exists(/databases/$(database)/documents/tribes/$(id)/members/$(request.auth.uid));
        allow create: if signedIn() && created('authorId')
          && exists(/databases/$(database)/documents/tribes/$(id)/members/$(request.auth.uid))
          && keysOnly(['authorId','authorName','authorPhotoURL','text','createdAt'])
          && strMax('text', 4000);
        allow update, delete: if false;
      }
    }

    // Direct-message threads — only the two participants can read or post.
    match /threads/{tid} {
      function participants() { return get(/databases/$(database)/documents/threads/$(tid)).data.participants; }
      function dmOther(list)  { return list[0] == request.auth.uid ? list[1] : list[0]; }
      // True if either user has blocked the other — blocks DMs in both directions.
      function blockedPair(a, b) {
        return exists(/databases/$(database)/documents/users/$(a)/blocked/$(b))
            || exists(/databases/$(database)/documents/users/$(b)/blocked/$(a));
      }
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2
        && keysOnly(['participants','participantNames','participantPhotos','lastMessage','lastAt','createdAt'])
        && !blockedPair(request.auth.uid, dmOther(request.resource.data.participants));
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && unchanged(['participants','createdAt']);
      allow delete: if false;
      match /messages/{mid} {
        allow read: if signedIn() && request.auth.uid in participants();
        allow create: if signedIn() && created('senderId')
          && request.auth.uid in participants()
          && keysOnly(['senderId','text','createdAt']) && strMax('text', 4000)
          && !blockedPair(request.auth.uid, dmOther(participants()));
        allow update, delete: if false;
      }
    }

    match /listings/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && created('sellerId')
        && keysOnly(['sellerId','sellerName','title','description','price','currency','type','category','photos','status','createdAt'])
        && strMax('title', 200) && request.resource.data.price is number && request.resource.data.price >= 0;
      allow update: if owns('sellerId') && unchanged(['sellerId','createdAt']);
      allow delete: if owns('sellerId');
    }

    match /reports/{id} {
      allow create: if signedIn() && created('reporterId')
        && keysOnly(['reporterId','targetType','targetId','targetOwnerId','reason','note','status','createdAt']);
      allow read, update, delete: if false; // triage in console only
    }

    // Identity verification submissions — write-only for the owner; reviewed out-of-band.
    // status is forced to 'pending' so a user can't submit themselves pre-'approved';
    // selfie is a Storage download URL, capped to block oversized payloads.
    match /verifications/{uid} {
      allow read: if false;
      allow create: if isUser(uid) && keysOnly(['uid','selfie','status','createdAt'])
        && request.resource.data.status == 'pending' && strMax('selfie', 2000);
      allow update, delete: if false;
    }

    // Trip safety plans — readable by the owner and invited partners.
    // Reads return the WHOLE doc, so the shareMedical toggle can't gate the medical
    // field at read time. Instead we enforce the invariant at write time: medical
    // must be null unless the owner opted in (shareMedical == true). That way an
    // invited partner can only ever see medical the owner explicitly chose to share.
    match /tripPlans/{id} {
      function medicalOk() {
        return request.resource.data.get('shareMedical', false) == true
            || request.resource.data.get('medical', null) == null;
      }
      allow read: if signedIn() && (owns('ownerId') || (request.auth.uid in resource.data.partners));
      allow create: if signedIn() && created('ownerId')
        && keysOnly(['ownerId','ownerName','objective','activity','area','startAt','expectedReturnAt','partners','emergencyContact','shareMedical','medical','lastKnownLocation','status','checkedInAt','escalatedAt','graceMins','createdAt'])
        && strMax('objective', 200) && strMax('area', 500) && medicalOk();
      allow update: if owns('ownerId') && unchanged(['ownerId','createdAt']) && medicalOk();
      allow delete: if owns('ownerId');
    }

    // Server-only (Admin SDK / Cloud Functions). Clients can neither read nor write.
    match /rateLimits/{uid} { allow read, write: if false; }
    match /abuseFlags/{id}  { allow read, write: if false; }
  }
}
