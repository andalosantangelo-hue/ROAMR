rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()        { return request.auth != null; }
    function isUser(uid)       { return signedIn() && request.auth.uid == uid; }
    function created(field)    { return request.resource.data[field] == request.auth.uid; }
    function owns(field)       { return signedIn() && resource.data[field] == request.auth.uid; }
    function keysOnly(allowed) { return request.resource.data.keys().hasOnly(allowed); }
    function unchanged(fields) { return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields); }
    function strMax(f, n)      { return request.resource.data[f] is string && request.resource.data[f].size() <= n; }

    // Collection-group reads of the current user's own presence docs
    match /{path=**}/members/{uid}   { allow read: if signedIn(); }
    match /{path=**}/likes/{uid}     { allow read: if signedIn(); }
    match /{path=**}/attendees/{uid} { allow read: if signedIn(); }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isUser(uid)
        && keysOnly(['uid','displayName','photoURL','updatedAt',
                     'interests','subInterests','skillLevels','bio','location','subscription','followingCount','followerCount','createdAt']);
      // owner-only; counters + subscription are server-maintained
      allow update: if isUser(uid)
        && keysOnly(['uid','displayName','photoURL','bio','interests','subInterests','skillLevels','location','subscription','followerCount','followingCount','createdAt','updatedAt'])
        && unchanged(['uid','followerCount','followingCount','subscription','createdAt']);
      allow delete: if isUser(uid);

      // Private profile data (email, phone, push tokens, prefs) — owner only.
      match /private/{doc} {
        allow read, write: if isUser(uid);
      }

      match /saves/{postId} {
        allow read: if isUser(uid);
        allow create: if isUser(uid) && keysOnly(['postId','collection','createdAt']);
        allow delete: if isUser(uid);
      }
      match /following/{targetUid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['targetUid','createdAt']);
        allow delete: if isUser(uid);
      }
      match /blocked/{targetUid} {
        allow read, delete: if isUser(uid);
        allow create: if isUser(uid) && keysOnly(['targetUid','createdAt']);
      }
      match /notifications/{nid} {
        allow read: if isUser(uid);
        allow update: if isUser(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false; // server-only
      }
      match /followers/{fid} { allow read: if signedIn(); allow write: if false; }
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && created('authorId')
        && request.resource.data.likeCount == 0 && request.resource.data.commentCount == 0
        && keysOnly(['authorId','authorName','authorPhotoURL','title','location','photo','rating','likeCount','commentCount','createdAt'])
        && strMax('title', 300);
      allow update: if owns('authorId') && unchanged(['authorId','likeCount','commentCount','createdAt']);
      allow delete: if owns('authorId');
      match /likes/{uid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['uid','createdAt']);
        allow delete: if isUser(uid);
      }
      match /comments/{cid} {
        allow read: if signedIn();
        allow create: if signedIn() && created('authorId')
          && keysOnly(['authorId','authorName','authorPhotoURL','text','createdAt']) && strMax('text', 2000);
        allow update, delete: if owns('authorId');
      }
    }

    match /activities/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && created('authorId')
        && request.resource.data.attendeeCount == 0 && request.resource.data.likeCount == 0 && request.resource.data.commentCount == 0
        && keysOnly(['authorId','authorName','authorPhotoURL','text','photo','location','when','skillLevel','dmOpen','attendeeCount','recentAttendees','likeCount','commentCount','createdAt'])
        && strMax('text', 2000);
      allow update: if owns('authorId') && unchanged(['authorId','attendeeCount','recentAttendees','likeCount','commentCount','createdAt']);
      allow delete: if owns('authorId');
      match /attendees/{uid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['uid','displayName','photoURL','createdAt']);
        allow delete: if isUser(uid);
      }
      match /likes/{uid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['uid','createdAt']);
        allow delete: if isUser(uid);
      }
      match /comments/{cid} {
        allow read: if signedIn();
        allow create: if signedIn() && created('authorId')
          && keysOnly(['authorId','authorName','authorPhotoURL','text','createdAt']) && strMax('text', 2000);
        allow update, delete: if owns('authorId');
      }
    }

    match /tribes/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && created('ownerId') && request.resource.data.memberCount == 0
        && keysOnly(['name','img','category','categories','location','description','memberCount','ownerId','createdAt'])
        && strMax('name', 120);
      allow update: if owns('ownerId') && unchanged(['ownerId','memberCount','createdAt']);
      allow delete: if owns('ownerId');
      match /members/{uid} {
        allow read: if signedIn();
        allow create: if isUser(uid) && keysOnly(['uid','role','createdAt']);
        allow delete: if isUser(uid);
      }
      // Group chat — members only.
      match /messages/{mid} {
        allow read: if signedIn()
          && exists(/databases/$(database)/documents/tribes/$(id)/members/$(request.auth.uid));
        allow create: if signedIn() && created('authorId')
          && exists(/databases/$(database)/documents/tribes/$(id)/members/$(request.auth.uid))
          && keysOnly(['authorId','authorName','authorPhotoURL','text','createdAt'])
          && strMax('text', 4000);
        allow update, delete: if false;
      }
    }

    // Direct-message threads — only the two participants can read or post.
    match /threads/{tid} {
      function participants() { return get(/databases/$(database)/documents/threads/$(tid)).data.participants; }
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2
        && keysOnly(['participants','participantNames','participantPhotos','lastMessage','lastAt','createdAt']);
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && unchanged(['participants','createdAt']);
      allow delete: if false;
      match /messages/{mid} {
        allow read: if signedIn() && request.auth.uid in participants();
        allow create: if signedIn() && created('senderId')
          && request.auth.uid in participants()
          && keysOnly(['senderId','text','createdAt']) && strMax('text', 4000);
        allow update, delete: if false;
      }
    }

    match /listings/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && created('sellerId')
        && keysOnly(['sellerId','sellerName','title','description','price','currency','type','category','photos','status','createdAt'])
        && strMax('title', 200) && request.resource.data.price is number && request.resource.data.price >= 0;
      allow update: if owns('sellerId') && unchanged(['sellerId','createdAt']);
      allow delete: if owns('sellerId');
    }

    match /reports/{id} {
      allow create: if signedIn() && created('reporterId')
        && keysOnly(['reporterId','targetType','targetId','targetOwnerId','reason','note','status','createdAt']);
      allow read, update, delete: if false; // triage in console only
    }

    // Server-only (Admin SDK / Cloud Functions). Clients can neither read nor write.
    match /rateLimits/{uid} { allow read, write: if false; }
    match /abuseFlags/{id}  { allow read, write: if false; }
  }
}
