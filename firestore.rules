rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isUser(uid) { return signedIn() && request.auth.uid == uid; }
    function creating(field) { return request.resource.data[field] == request.auth.uid; }
    function owns(field) { return signedIn() && resource.data[field] == request.auth.uid; }

    // Current user's own presence docs across all parents (collection-group reads)
    match /{path=**}/members/{uid}   { allow read: if signedIn(); }
    match /{path=**}/likes/{uid}     { allow read: if signedIn(); }
    match /{path=**}/attendees/{uid} { allow read: if signedIn(); }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isUser(uid);
      // owner-only; counters/subscription are server-maintained, block client tampering
      allow update: if isUser(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['followerCount', 'followingCount', 'subscription', 'createdAt']);
      allow delete: if isUser(uid);

      match /saves/{postId}      { allow read, write: if isUser(uid); }
      match /following/{targetUid} { allow read: if signedIn(); allow write: if isUser(uid); }
      match /blocked/{targetUid} { allow read, write: if isUser(uid); }
      match /followers/{fid}     { allow read: if signedIn(); allow write: if false; }
      match /notifications/{nid} { allow read: if isUser(uid); allow update: if isUser(uid); allow create, delete: if false; }
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && creating('authorId')
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0;
      allow update, delete: if owns('authorId'); // counts updated by Cloud Functions (admin bypasses rules)
      match /likes/{uid} {
        allow read: if signedIn();
        allow create, delete: if isUser(uid);
      }
      match /comments/{cid} {
        allow read: if signedIn();
        allow create: if signedIn() && creating('authorId');
        allow update, delete: if owns('authorId');
      }
    }

    match /activities/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && creating('authorId')
        && request.resource.data.attendeeCount == 0
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0;
      allow update, delete: if owns('authorId');
      match /attendees/{uid} { allow read: if signedIn(); allow create, delete: if isUser(uid); }
      match /likes/{uid}     { allow read: if signedIn(); allow create, delete: if isUser(uid); }
      match /comments/{cid} {
        allow read: if signedIn();
        allow create: if signedIn() && creating('authorId');
        allow update, delete: if owns('authorId');
      }
    }

    match /tribes/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && creating('ownerId')
        && request.resource.data.memberCount == 0;
      allow update, delete: if owns('ownerId');
      match /members/{uid} { allow read: if signedIn(); allow create, delete: if isUser(uid); }
    }

    match /listings/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && creating('sellerId');
      allow update, delete: if owns('sellerId');
    }

    match /reports/{id} {
      allow create: if signedIn() && creating('reporterId');
      allow read, update, delete: if false; // triage in console only
    }
  }
}
