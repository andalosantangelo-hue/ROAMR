# Optional integrations — copy to .env.local and fill in to enable.
# (Firebase web config is public and lives in src/lib/firebase.js — not here.)

# Error logging (Sentry): create a project at sentry.io, paste its DSN.
VITE_SENTRY_DSN=

# App Check (bot/abuse + rate-limit protection): reCAPTCHA v3 site key from
# Firebase console → App Check. Leave blank to disable in dev.
VITE_RECAPTCHA_SITE_KEY=
