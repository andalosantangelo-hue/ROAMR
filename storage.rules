rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function img() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif|heic|heif)');
    }
    function isUser(uid) { return request.auth != null && request.auth.uid == uid; }

    // Tribe images are scoped to the uploader's uid so one user can't overwrite
    // another's images or dump arbitrary objects under the shared tribes/ prefix.
    match /tribes/{uid}/{f=**}     { allow read: if true; allow write: if isUser(uid) && img(); }
    match /avatars/{uid}/{f=**}    { allow read: if true; allow write: if isUser(uid) && img(); }
    match /posts/{uid}/{f=**}      { allow read: if true; allow write: if isUser(uid) && img(); }
    match /activities/{uid}/{f=**} { allow read: if true; allow write: if isUser(uid) && img(); }
    match /listings/{uid}/{f=**}   { allow read: if true; allow write: if isUser(uid) && img(); }
    // Verification selfies are PRIVATE — only the owner (and Admin via console) can read.
    match /verifications/{uid}/{f=**} { allow read: if isUser(uid); allow write: if isUser(uid) && img(); }
  }
}
